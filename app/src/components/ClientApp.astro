---
// Single client island: wires observers, parallax, share popup, smooth
// anchors, and the tweaks panel. The heavy logic lives in ~/lib/* modules
// (share, scroll, tweaks) to keep this component within the .astro LOC budget
// (AC-6). EDIT MODE sentinel preserved verbatim here (do not rename markers).
---
<script>
  import { observeReveals, observeValueArt, attachHeroParallax, observeSpecIndex, observeFocusBand } from '~/lib/observers';
  import { initSharePopup } from '~/lib/share';
  import { initSmoothAnchors } from '~/lib/scroll';
  import { initTweaks, type TweakState } from '~/lib/tweaks';

  observeReveals();
  observeValueArt();
  attachHeroParallax();
  observeSpecIndex();
  observeFocusBand();

  initSharePopup();
  initSmoothAnchors();

  // Service worker removed — unregister any previously-installed one (the /sw.js
  // kill-switch also self-destructs for tabs still controlled by the old worker).
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.getRegistrations?.()
      .then((regs) => regs.forEach((r) => r.unregister()))
      .catch(() => {});
  }

  const modelContext = (navigator as any).modelContext;
  if (modelContext?.registerTool) {
    modelContext.registerTool(
      {
        name: 'get_manifesto',
        description: 'Return the AI-Driven Development manifesto as structured JSON.',
        inputSchema: { type: 'object', properties: {}, additionalProperties: false },
      },
      async () => fetch('/manifesto.json').then((r) => r.json())
    );
  }

  // The defaults literal — and its EDITMODE sentinel — must stay here verbatim
  // so the parent-iframe editor keeps finding the markers (do not rename).
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "accentHue": 275,
    "paper": "ice",
    "serifScale": 1,
    "rainbow": false
  }/*EDITMODE-END*/;
  initTweaks(TWEAK_DEFAULTS as TweakState);
</script>
