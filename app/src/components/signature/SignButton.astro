---
// CTA that opens the signature Issue Form. Actions turns the submitted issue
// into a reviewed pull request. The signer's handle is read from the issue
// author, never from a field, so nobody can sign in someone else's name.
//
// No query params: the page is static and knows nothing about the visitor. The
// form carries its own placeholders, which are hints rather than submitted text.

import { SITE } from '~/lib/site';

interface Props {
  /** 'github' (default, bottom CTA) or 'aidd' (animated brand mark, sidebar). */
  logo?: 'github' | 'aidd';
  /** 'sidebar' renders a compact, full-width variant. */
  variant?: 'default' | 'sidebar';
}
const { logo = 'github', variant = 'default' } = Astro.props;
---
<a
  class:list={['sign-btn', variant === 'sidebar' && 'sign-btn--sidebar']}
  href={SITE.signUrl}
  data-github-url={SITE.signUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Start your public signature on GitHub"
>
  <span class="sign-btn-icon" aria-hidden="true">
    {logo === 'aidd' ? (
      <svg class="sign-logo" viewBox="0 0 100 100" focusable="false">
        <line class="sl-bar-small" x1="8" y1="92" x2="28" y2="62" stroke="currentColor" stroke-width="14" stroke-linecap="round" pathLength="100" />
        <line class="sl-bar-big" x1="60" y1="8" x2="92" y2="92" stroke="currentColor" stroke-width="22" stroke-linecap="round" pathLength="100" />
        <circle class="sl-dot" cx="42" cy="41" r="10" fill="currentColor" />
      </svg>
    ) : (
      <svg viewBox="0 0 16 16" focusable="false">
        <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    )}
  </span>
  <span class="sign-btn-body">
    <span class="sign-btn-label">Start your GitHub signature</span>
    <svg class="sign-btn-sig" viewBox="0 0 240 32" aria-hidden="true" focusable="false">
      <path pathLength="100" d="M6 22 C 14 6, 24 6, 26 16 C 27 23, 21 24, 20 19 C 19 13, 30 11, 40 17 C 49 22, 53 11, 62 15 C 72 19, 70 28, 62 27 C 55 26, 60 15, 73 15 C 88 15, 96 24, 110 20 C 119 17, 122 9, 132 13 C 141 16, 138 27, 130 26 C 123 25, 128 14, 142 15 C 160 16, 172 25, 196 18 C 210 14, 222 16, 236 24" />
    </svg>
  </span>
  <span class="sign-btn-chev" aria-hidden="true">→</span>
</a>
