---
---
<div id="tweaks">
  <h4>Tweaks</h4>
  <div class="row">
    <label>Accent</label>
    <div class="swatches" id="swatches">
      <button class="swatch" data-hue="28" style="background: oklch(0.52 0.17 28)"></button>
      <button class="swatch" data-hue="145" style="background: oklch(0.52 0.14 145)"></button>
      <button class="swatch" data-hue="250" style="background: oklch(0.52 0.17 250)"></button>
      <button class="swatch" data-hue="310" style="background: oklch(0.52 0.17 310)"></button>
      <button class="swatch" data-hue="60" style="background: oklch(0.52 0.14 60)"></button>
    </div>
  </div>
  <div class="row">
    <label>Paper</label>
    <select id="paperSel">
      <option value="warm">Warm</option>
      <option value="cool">Cool</option>
      <option value="ink">Ink</option>
    </select>
  </div>
  <div class="row">
    <label>Serif size</label>
    <input type="range" id="serifScale" min="0.9" max="1.15" step="0.01" />
  </div>
  <div class="row">
    <label>Rainbow principles</label>
    <input type="checkbox" id="rainbowToggle" />
  </div>
</div>
