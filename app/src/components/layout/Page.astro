---
import '~/styles/fonts.css';
import '~/styles/tokens.css';
import '~/styles/sections/base.css';
import '~/styles/sections/cover.css';
import '~/styles/sections/layout.css';
import '~/styles/sections/preamble.css';
import '~/styles/sections/chapters.css';
import '~/styles/sections/values.css';
import '~/styles/sections/value-art.css';
import '~/styles/sections/principles.css';
import '~/styles/sections/terminal.css';
import '~/styles/sections/signature.css';
import '~/styles/sections/footer.css';
import '~/styles/sections/reveal.css';
import '~/styles/sections/icons.css';
import '~/styles/sections/responsive.css';
import '~/styles/sections/print.css';
import '~/styles/sections/tweaks.css';
import { absoluteUrl, SITE } from '~/lib/site';
import { getHomeJsonLd } from '~/lib/manifesto';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  noindex?: boolean;
  jsonLd?: unknown;
}
const {
  title = SITE.name,
  description = SITE.description,
  path = '/',
  noindex = false,
  jsonLd = getHomeJsonLd(),
} = Astro.props;
const canonical = absoluteUrl(path);
const ogImage = absoluteUrl('/og-image.png');
const pageTitle = title === SITE.name ? title : `${title} | ${SITE.shortName}`;
---
<!doctype html>
<html lang={SITE.lang} dir={SITE.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content={SITE.themeLight} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content={SITE.themeDark} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,follow' : 'index,follow'} />
    <meta name="generator" content="Astro" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.shortName} feed`} href="/feed.xml" />
    <link rel="alternate" type="text/markdown" title={`${SITE.shortName} Markdown`} href="/index.md" />
    <link rel="describedby" type="application/ld+json" href="/schema/home.jsonld" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="oklch(0.18 0.12 280)" />
    <link
      rel="preload"
      href="/fonts/bricolage-grotesque-latin-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
