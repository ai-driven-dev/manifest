---
---
<dialog id="downvoteDialog" class="downvote-dialog">
  <form method="dialog" id="downvoteForm" class="dv-form">
    <h4>Tell us why.</h4>
    <p class="dv-hint">Your downvote is recorded. A reason and an alternative help refine the manifesto.</p>
    <input type="hidden" id="dvTargetType" />
    <input type="hidden" id="dvTargetId" />
    <label>Reason
      <textarea id="dvReason" rows="3" maxlength="500" required placeholder="What rings false?"></textarea>
    </label>
    <label>Alternative
      <textarea id="dvAlternative" rows="3" maxlength="500" required placeholder="What would you write instead?"></textarea>
    </label>
    <div class="dialog-actions">
      <button type="button" class="dialog-cancel" data-close>Skip</button>
      <button type="submit" class="sign-action">Send <span class="arrow">→</span></button>
    </div>
  </form>
</dialog>
<style>
.downvote-dialog { border: 1px solid var(--rule); padding: 24px; border-radius: 4px; background: var(--paper); color: var(--ink); max-width: 480px; width: 92vw; }
.downvote-dialog::backdrop { background: oklch(0.18 0.012 60 / 0.45); }
.downvote-dialog h4 { font-family: var(--serif); font-size: 22px; margin-bottom: 8px; }
.dv-hint { font-family: var(--sans); font-size: 13px; color: var(--ink-3); margin-bottom: 16px; }
.dv-form { display: grid; gap: 12px; }
.dv-form label { display: grid; gap: 6px; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.06em; text-transform: uppercase; }
.dv-form textarea { font-family: var(--sans); font-size: 14px; padding: 10px 12px; border: 1px solid var(--rule); background: var(--paper-2); color: var(--ink); border-radius: 2px; resize: vertical; }
.dialog-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px; }
.dialog-cancel { background: none; border: 1px solid var(--rule); padding: 8px 14px; cursor: pointer; font-family: var(--mono); font-size: 11px; color: var(--ink-2); border-radius: 2px; }
</style>
