---
// Cover section — preserves seal, orbits, infall particles, title.
---
<section class="cover" data-screen-label="Cover">
  <div class="cover-seal" aria-hidden="true">
    <div class="orbit r1"></div>
    <div class="orbit r2"></div>
    <div class="orbit r3"></div>

    <div class="infall">
      <i style="--x:-220px;--y:-120px;animation-delay:.2s"></i>
      <i style="--x:260px;--y:-80px;animation-delay:1.1s"></i>
      <i style="--x:180px;--y:200px;animation-delay:2.0s"></i>
      <i style="--x:-240px;--y:160px;animation-delay:2.9s"></i>
      <i style="--x:-40px;--y:-300px;animation-delay:3.6s"></i>
      <i style="--x:300px;--y:40px;animation-delay:4.4s"></i>
      <i style="--x:-300px;--y:-20px;animation-delay:5.0s"></i>
      <i style="--x:20px;--y:290px;animation-delay:5.7s"></i>
    </div>

    <div class="ring r1">
      <span class="orb lg pos-0" style="--i:0"><span class="glyph">{'{ }'}</span></span>
      <span class="orb lg pos-120" style="--i:1"><span class="glyph">&lt;/&gt;</span></span>
      <span class="orb lg pos-240" style="--i:2"><span class="glyph">$_</span></span>
    </div>

    <div class="ring r2">
      <span class="orb md pos-0" style="--i:0"><span class="glyph">git</span></span>
      <span class="orb md pos-60" style="--i:1"><span class="glyph">( )</span></span>
      <span class="orb md pos-120" style="--i:2"><span class="glyph">=&gt;</span></span>
      <span class="orb md pos-180" style="--i:3"><span class="glyph">λ</span></span>
      <span class="orb md pos-240" style="--i:4"><span class="glyph">#!</span></span>
      <span class="orb md pos-300" style="--i:5"><span class="glyph">[ ]</span></span>
    </div>

    <div class="ring r3">
      <span class="orb sm pos-0" style="--i:0"><span class="glyph">;</span></span>
      <span class="orb sm pos-30" style="--i:1"><span class="glyph">*</span></span>
      <span class="orb sm pos-60" style="--i:2"><span class="glyph">//</span></span>
      <span class="orb sm pos-90" style="--i:3"><span class="glyph">&gt;_</span></span>
      <span class="orb sm pos-120" style="--i:4"><span class="glyph">::</span></span>
      <span class="orb sm pos-150" style="--i:5"><span class="glyph">&amp;&amp;</span></span>
      <span class="orb sm pos-180" style="--i:6"><span class="glyph">!=</span></span>
      <span class="orb sm pos-210" style="--i:7"><span class="glyph">|&gt;</span></span>
      <span class="orb sm pos-240" style="--i:8"><span class="glyph">...</span></span>
      <span class="orb sm pos-270" style="--i:9"><span class="glyph">??</span></span>
      <span class="orb sm pos-300" style="--i:10"><span class="glyph">++</span></span>
      <span class="orb sm pos-330" style="--i:11"><span class="glyph">⟳</span></span>
    </div>
  </div>

  <header class="cover-top">
    <div><span class="dot"></span>A Living Document · v1.0</div>
    <nav>
      <a href="#preamble">Preamble</a>
      <a href="#values">Values</a>
      <a href="#principles">Principles</a>
      <a href="#sign">Sign</a>
    </nav>
  </header>

  <div class="cover-center">
    <div class="eyebrow">2026 · First Edition</div>
    <h1 class="cover-title">
      <span class="word">The</span> <span class="word">Manifesto</span>
      <span class="for word">for</span>
      <span class="word"><span class="ai">AI-Driven</span></span>
      <span class="word">Development.</span>
    </h1>
    <div class="cover-date">
      <span>№ 01 / 01</span>
      <span data-signature-counter>Free to sign · <span data-signature-count>0</span> signed</span>
      <span>Free to fork</span>
    </div>
  </div>
</section>
