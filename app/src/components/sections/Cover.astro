---
// Cover — standard splash: a version header, a huge confident title, two entry links.
// The AIDD mark stays as a faint watermark (parallax hook); two hairlines frame the fold.
---
<section class="cover" data-screen-label="Cover">
  <svg class="cover-watermark" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true" focusable="false">
    <line class="cw-bar-small" x1="8" y1="92" x2="28" y2="62" stroke="currentColor" stroke-width="14" stroke-linecap="round" />
    <circle class="cw-dot" cx="42" cy="41" r="10" fill="currentColor" />
    <line class="cw-bar-big" x1="60" y1="8" x2="92" y2="92" stroke="currentColor" stroke-width="22" stroke-linecap="round" />
  </svg>

  <div class="cover-rule cover-rule-top" aria-hidden="true"></div>
  <div class="cover-rule cover-rule-bottom" aria-hidden="true"></div>

  <div class="cover-stage">
    <p class="cover-std reveal-word" style="--d:.02s">AIDD <span class="cs-sep">·</span> Manifesto <span class="cs-sep">·</span> v1.1 <span class="cs-sep">·</span> 2026</p>

    <h1 class="cover-title">
      <span class="line line-1"><span class="word reveal-word" style="--d:.12s">The</span></span>
      <span class="line line-3"><span class="word ai reveal-word" style="--d:.26s">
        <span class="ai-text">AI-Driven</span>
        <span class="ai-strike" aria-hidden="true"></span>
      </span></span>
      <span class="line line-4"><span class="word reveal-word" style="--d:.40s">Development</span></span>
      <span class="line line-2"><span class="word for reveal-word" style="--d:.54s">Manifesto</span></span>
    </h1>

    <div class="cover-foot reveal-word" style="--d:.72s">
      <p class="cover-lede">A standard for building software in the age of AI — written by developers, for developers.</p>
      <nav class="cover-cta" aria-label="Manifesto entry points">
        <a class="cover-link cover-link-primary" href="#sign" style="--cta-i:0">
          <span class="cover-link-icon cover-link-icon-aidd" aria-hidden="true">
            <svg viewBox="0 0 100 100" focusable="false">
              <line x1="8" y1="92" x2="28" y2="62" stroke="currentColor" stroke-width="14" stroke-linecap="round" />
              <circle cx="42" cy="41" r="10" fill="currentColor" />
              <line x1="60" y1="8" x2="92" y2="92" stroke="currentColor" stroke-width="22" stroke-linecap="round" />
            </svg>
          </span>
          <span>Sign</span>
        </a>
        <a class="cover-link cover-link-github" href="https://github.com/ai-driven-dev/framework" target="_blank" rel="noopener" style="--cta-i:1">
          <span class="cover-link-icon cover-link-icon-github" aria-hidden="true">
            <svg viewBox="0 0 16 16" focusable="false">
              <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </span>
          <span class="cover-link-copy">
            <span class="cover-link-kicker">GitHub</span>
            <span class="cover-link-main">Install the Framework</span>
          </span>
          <span class="cl-ext" aria-hidden="true">↗</span>
        </a>
      </nav>
    </div>
  </div>
</section>
