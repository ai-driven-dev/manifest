---
interface Props {
  anim: 'v1' | 'v2' | 'v3' | 'v4';
}
const { anim } = Astro.props;
---
{anim === 'v1' && (
  <div class="value-art" data-anim="v1">
    <div class="va-col va-good">
      <div class="va-col-head"><span class="va-col-label">method</span><span class="va-col-badge">do</span></div>
      <pre><span class="va-l" style="--i:0">  plan <span class="va-key">──→</span> implement</span>
<span class="va-l" style="--i:1">    <span class="va-key">↑</span>          <span class="va-key">↓</span></span>
<span class="va-l" style="--i:2">  assert <span class="va-key">←──</span> review</span>
<span class="va-l" style="--i:3"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:4"><span class="va-dim2">any ide · any model</span></span>
<span class="va-l" style="--i:5"><span class="va-key">workflow leads.</span><span class="va-cursor" style="--cd:1.5s"></span></span></pre>
    </div>
    <div class="va-sep"></div>
    <div class="va-col va-bad">
      <div class="va-col-head"><span class="va-col-label">model</span><span class="va-col-badge">don't</span></div>
      <pre><span class="va-l" style="--i:7"><span class="va-cmd">$</span> claude</span>
<span class="va-l" style="--i:8"><span class="va-cmd">$</span> codex</span>
<span class="va-l" style="--i:9"><span class="va-cmd">$</span> cursor</span>
<span class="va-l" style="--i:10"><span class="va-cmd">$</span> copilot</span>
<span class="va-l" style="--i:11"><span class="va-dim2">…</span></span>
<span class="va-l" style="--i:12"><span class="va-dim2">swap tools · same speed.</span></span></pre>
    </div>
  </div>
)}
{anim === 'v2' && (
  <div class="value-art" data-anim="v2">
    <div class="va-col va-good">
      <div class="va-col-head"><span class="va-col-label">ownership</span><span class="va-col-badge">do</span></div>
      <pre><span class="va-l" style="--i:0"><span class="va-cmd">$</span> git commit</span>
<span class="va-l" style="--i:1">  → reviewed   <span class="va-ok">✓</span></span>
<span class="va-l" style="--i:2">  → tested     <span class="va-ok">✓</span></span>
<span class="va-l" style="--i:3"><span class="va-key">Signed-off-by:</span> you <span class="va-ok">✓</span></span>
<span class="va-l" style="--i:4"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:5"><span class="va-dim2">the human owns it.</span><span class="va-cursor" style="--cd:1.4s"></span></span></pre>
    </div>
    <div class="va-sep"></div>
    <div class="va-col va-bad">
      <div class="va-col-head"><span class="va-col-label">delegation</span><span class="va-col-badge">don't</span></div>
      <pre><span class="va-l" style="--i:7"><span class="va-cmd">$</span> ai <span class="va-str">"ship it"</span></span>
<span class="va-l" style="--i:8"><span class="va-key">+</span> 1,240 lines      <span class="va-dim2">merged</span></span>
<span class="va-l" style="--i:9"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:10"><span class="va-err">⚠</span> no review</span>
<span class="va-l" style="--i:11">  <span class="va-dim2">nobody read it.</span></span>
<span class="va-l" style="--i:12"><span class="va-warn">who owns this?</span></span></pre>
    </div>
  </div>
)}
{anim === 'v3' && (
  <div class="value-art" data-anim="v3">
    <div class="va-col va-good">
      <div class="va-col-head"><span class="va-col-label">understanding</span><span class="va-col-badge">do</span></div>
      <pre><span class="va-l" style="--i:0"><span class="va-key">ai:</span> auth via JWT.</span>
<span class="va-l" style="--i:1"><span class="va-cmd">$</span> why? we use</span>
<span class="va-l" style="--i:2">  HttpOnly sessions.</span>
<span class="va-l" style="--i:3"><span class="va-key">ai:</span> rewriting. <span class="va-ok">✓</span></span>
<span class="va-l" style="--i:4"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:5"><span class="va-dim2">you understood.</span><span class="va-cursor" style="--cd:1.5s"></span></span></pre>
    </div>
    <div class="va-sep"></div>
    <div class="va-col va-bad">
      <div class="va-col-head"><span class="va-col-label">acceptance</span><span class="va-col-badge">don't</span></div>
      <pre><span class="va-l" style="--i:7"><span class="va-key">ai:</span> auth via JWT.</span>
<span class="va-l" style="--i:8"><span class="va-cmd">$</span> ok            <span class="va-dim2">accept</span></span>
<span class="va-l" style="--i:9"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:10"><span class="va-err">⚠</span> 3am</span>
<span class="va-l" style="--i:11">  <span class="va-dim2">why is this here?</span></span>
<span class="va-l" style="--i:12"><span class="va-warn">nobody knows.</span></span></pre>
    </div>
  </div>
)}
{anim === 'v4' && (
  <div class="value-art" data-anim="v4">
    <div class="va-col va-good">
      <div class="va-col-head"><span class="va-col-label">outcome</span><span class="va-col-badge">do</span></div>
      <pre><span class="va-l" style="--i:0">users helped      <span class="va-ok">+410</span></span>
<span class="va-l" style="--i:1">task time          <span class="va-ok">-32%</span></span>
<span class="va-l" style="--i:2">incidents avoided    <span class="va-ok">✓</span></span>
<span class="va-l" style="--i:3"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:4"><span class="va-dim2">outcomes improved.</span><span class="va-cursor" style="--cd:1.4s"></span></span></pre>
    </div>
    <div class="va-sep"></div>
    <div class="va-col va-bad">
      <div class="va-col-head"><span class="va-col-label">output</span><span class="va-col-badge">don't</span></div>
      <pre><span class="va-l" style="--i:7">lines generated  <span class="va-warn">12k</span></span>
<span class="va-l" style="--i:8">tokens burned   <span class="va-warn">1.2M</span></span>
<span class="va-l" style="--i:9">commits/day       <span class="va-warn">38</span></span>
<span class="va-l" style="--i:10"><span class="va-dim2">———————————————</span></span>
<span class="va-l" style="--i:11"><span class="va-dim2">…</span></span>
<span class="va-l" style="--i:12"><span class="va-err">vanity · zero impact.</span></span></pre>
    </div>
  </div>
)}
