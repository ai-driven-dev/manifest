---
// Two schematics for AIDD vs vibe coding — a picture over prose.
// 1) Method: a quality-governed delivery loop vs prompt-to-prod.
// 2) Over time: durable value trajectory. Strokes use oklch tokens via CSS.
---
<div class="vsch-grid">

  <!-- 1 — METHOD -->
  <figure class="vsch">
    <figcaption class="vsch-cap">Method</figcaption>
    <svg class="vsch-svg" viewBox="0 0 300 214" role="img"
      aria-label="AIDD moves from intent through spec, plan, implementation, review and testing, then release and learning; vibe coding moves directly from prompt to production.">
      <defs>
        <marker id="m1a" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path d="M0 .5 L6 3 L0 5.5" class="ah-a"/></marker>
        <marker id="m1m" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path d="M0 .5 L6 3 L0 5.5" class="ah-m"/></marker>
      </defs>

      <!-- AIDD track -->
      <text x="16" y="27" class="tag tag--a">AIDD</text>
      <path d="M26 63 H62 M74 63 H110 M122 63 H158 M170 63 H208 M230 63 H270" class="seg" marker-end="url(#m1m)"/>
      <path d="M276 50 C 238 18, 76 18, 28 50" class="arc-a" marker-end="url(#m1a)"/>
      <text x="154" y="17" class="micro micro--a">learn</text>
      <circle cx="22" cy="63" r="4" class="stn"/>
      <circle cx="70" cy="63" r="4" class="stn"/>
      <circle cx="118" cy="63" r="4" class="stn"/>
      <circle cx="166" cy="63" r="4" class="stn"/>
      <circle cx="220" cy="63" r="15" class="gate-halo"/>
      <circle cx="220" cy="63" r="9.5" class="gate"/>
      <path d="M215 63 l3.5 4 l6.5 -8" class="chk"/>
      <circle cx="276" cy="63" r="4" class="stn"/>
      <text x="22" y="86" class="lbl">intent</text>
      <text x="70" y="86" class="lbl">spec</text>
      <text x="118" y="86" class="lbl">plan</text>
      <text x="166" y="86" class="lbl">implement</text>
      <text x="220" y="85" class="lbl lbl--a">review</text>
      <text x="220" y="97" class="micro micro--a">+ test</text>
      <text x="276" y="86" class="lbl">release</text>

      <line x1="16" y1="116" x2="284" y2="116" class="rule-faint"/>

      <!-- Vibe track -->
      <text x="20" y="142" class="tag tag--m">VIBE CODING</text>
      <path d="M76 164 H224" class="seg" marker-end="url(#m1m)"/>
      <circle cx="70" cy="164" r="4.5" class="stn-m"/>
      <circle cx="230" cy="164" r="4.5" class="stn-m"/>
      <text x="70" y="186" class="lbl">prompt</text>
      <text x="230" y="186" class="lbl">prod</text>
    </svg>
  </figure>

  <!-- 2 — OVER TIME -->
  <figure class="vsch">
    <figcaption class="vsch-cap">Over time</figcaption>
    <svg class="vsch-svg" viewBox="0 0 300 196" role="img"
      aria-label="Vibe coding spikes early then decays into debt; AIDD starts steadier and accelerates, compounding into durable value.">
      <defs>
        <linearGradient id="areaA" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" class="g0"/>
          <stop offset="1" class="g1"/>
        </linearGradient>
      </defs>
      <line x1="44" y1="22" x2="44" y2="166" class="axis-ln"/>
      <line x1="44" y1="166" x2="284" y2="166" class="axis-ln"/>
      <text x="40" y="20" class="ax end">value</text>
      <text x="282" y="184" class="ax end">time</text>

      <path d="M50 156 C 124 150, 182 92, 278 28 L278 166 L50 166 Z" class="area"/>
      <path d="M50 156 C 74 60, 106 52, 136 84 C 174 116, 232 140, 278 150" class="curve-m"/>
      <path d="M50 156 C 124 150, 182 92, 278 28" class="curve-a"/>
      <circle cx="278" cy="150" r="3.6" class="dot-m"/>
      <circle cx="278" cy="28" r="4.2" class="dot-a"/>
      <text x="272" y="24" class="end-lbl end-lbl--a end">compounds</text>
      <text x="274" y="164" class="end-lbl end-lbl--m end">spikes, then debt</text>
    </svg>
  </figure>

</div>

<div class="vsch-quality" aria-label="The quality difference between AIDD and vibe coding">
  <p class="vsch-quality-aidd">
    <span>AIDD</span>
    <strong>Ship fast, with quality built into the process.</strong>
  </p>
  <p class="vsch-quality-vibe">
    <span>Vibe coding</span>
    <strong>Ship fast. Do not care about code quality.</strong>
  </p>
</div>
