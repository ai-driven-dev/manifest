---
interface Props {
  index: number;
}

const { index } = Astro.props;
const number = String(index + 1).padStart(2, '0');
const verifiedCells = Array.from({ length: 24 }, (_, i) => {
  const phase = i * 84;
  return `<span class="micro-cell" style="--phase:${phase}ms" aria-hidden="true"></span>`;
}).join('');
const factoryDemo = `<div class="scene-factory micro-table" role="img" aria-label="One table row of tiny cells turning green from left to right">${verifiedCells}</div>`;
const asciiSpecLines = [
  '+-- spec.md --------+',
  '| goal: clear build |',
  '| input: intent     |',
  '| steps:            |',
  '| [ ] scope         |',
  '| [ ] acceptance    |',
  '| [ ] review        |',
  '+-------------------+',
].map((line, i) => `<span class="ascii-line" style="--delay:${i * 280}ms">${line}</span>`).join('');
const specDemo = `<div class="scene-ascii-doc" role="img" aria-label="An ASCII specification document writing itself"><pre aria-hidden="true">${asciiSpecLines}<span class="ascii-cursor"></span></pre></div>`;
const demos = [
  factoryDemo,
  specDemo,
  `<svg class="scene-svg scene-map" viewBox="0 0 320 150" role="img" aria-label="Three step implementation map"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><path class="route-path" d="M42 96 C80 48, 128 112, 164 72 S244 62, 278 96"/><circle class="route-dot" cx="42" cy="96" r="5"/><g class="flag"><rect x="50" y="46" width="50" height="24" rx="5"/><text x="75" y="62">shape</text></g><g class="flag"><rect x="136" y="84" width="48" height="24" rx="5"/><text x="160" y="100">build</text></g><g class="flag final"><rect x="222" y="46" width="50" height="24" rx="5"/><text x="247" y="62">prove</text></g></svg><p>The plan is the route, not paperwork.</p>`,
  `<svg class="scene-svg scene-splitter" viewBox="0 0 320 150" role="img" aria-label="Task split into smaller leaves"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><rect class="root" x="36" y="60" width="58" height="34" rx="6"/><text x="65" y="81">task</text><path class="split-lines" d="M94 77 H140 M140 77 V42 H178 M140 77 V67 H178 M140 77 V88 H178 M140 77 V112 H178"/><g class="leaves"><rect x="178" y="30" width="52" height="24" rx="5"/><text x="204" y="46">api</text><rect x="178" y="58" width="52" height="24" rx="5"/><text x="204" y="74">auth</text><rect x="178" y="86" width="52" height="24" rx="5"/><text x="204" y="102">audit</text><rect x="178" y="114" width="52" height="24" rx="5"/><text x="204" y="130">e2e</text></g></svg><p>Large work is cut until it can move.</p>`,
  `<svg class="scene-svg scene-vault" viewBox="0 0 320 150" role="img" aria-label="Project memory vault"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><g class="drawer"><rect x="48" y="34" width="170" height="28" rx="6"/><text x="70" y="52">rules</text><rect x="66" y="66" width="170" height="28" rx="6"/><text x="88" y="84">skills</text><rect x="84" y="98" width="170" height="28" rx="6"/><text x="106" y="116">docs</text></g><g class="index-card"><rect x="232" y="44" width="46" height="76" rx="7"/><text x="255" y="84">memory</text></g></svg><p>Context becomes a maintained asset.</p>`,
  `<svg class="scene-svg scene-funnel" viewBox="0 0 320 150" role="img" aria-label="Learning capture funnel"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><rect class="waste" x="38" y="58" width="50" height="24" rx="5"/><text x="63" y="74">lost</text><path class="funnel-shape" d="M116 44 H186 L164 96 H138 Z"/><circle class="drop" cx="151" cy="52" r="5"/><g class="bins"><rect x="210" y="34" width="64" height="24" rx="5"/><text x="242" y="50">memory</text><rect x="210" y="64" width="64" height="24" rx="5"/><text x="242" y="80">rule</text><rect x="210" y="94" width="64" height="24" rx="5"/><text x="242" y="110">skill</text></g></svg><p>Learning is caught before it disappears.</p>`,
  `<svg class="scene-svg scene-stamp" viewBox="0 0 320 150" role="img" aria-label="Human review stamp"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><g class="diff"><rect x="42" y="38" width="126" height="78" rx="7"/><text x="70" y="62">AI diff</text><line x1="62" y1="78" x2="148" y2="78"/><line x1="62" y1="90" x2="138" y2="90"/></g><g class="stamp"><rect class="handle" x="218" y="32" width="42" height="26" rx="7"/><rect x="206" y="70" width="66" height="30" rx="6"/><text x="239" y="90">review</text><rect class="owned" x="198" y="104" width="82" height="24" rx="5"/><text x="239" y="120">owned</text></g></svg><p>Humans stamp what they maintain.</p>`,
  `<svg class="scene-svg scene-airlock" viewBox="0 0 320 150" role="img" aria-label="Evaluation gate before delegation"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><rect x="48" y="42" width="70" height="24" rx="5"/><text x="83" y="58">read</text><rect x="48" y="76" width="70" height="24" rx="5"/><text x="83" y="92">prove</text><g class="door"><rect class="door-panel" x="168" y="34" width="82" height="84" rx="7"/><rect class="delegate" x="180" y="82" width="92" height="28" rx="6"/><text x="226" y="100">delegate</text></g></svg><p>The gate opens only after evaluation.</p>`,
  `<svg class="scene-svg scene-tuner" viewBox="0 0 320 150" role="img" aria-label="System tuning around the model"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><circle class="core" cx="92" cy="76" r="34"/><text x="92" y="80">model</text><g class="sliders"><line x1="150" y1="48" x2="270" y2="48"/><circle class="knob" cx="190" cy="48" r="6"/><text x="150" y="40">tests</text><line x1="150" y1="78" x2="270" y2="78"/><circle class="knob" cx="220" cy="78" r="6"/><text x="150" y="70">names</text><line x1="150" y1="108" x2="270" y2="108"/><circle class="knob" cx="174" cy="108" r="6"/><text x="150" y="100">bounds</text></g></svg><p>Tune the system before the model.</p>`,
  `<svg class="scene-svg scene-reset" viewBox="0 0 320 150" role="img" aria-label="Context rebuild loop"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><rect class="drift" x="42" y="64" width="52" height="24" rx="5"/><text x="68" y="80">drift</text><path class="loop" d="M126 76 C126 42, 220 42, 220 76 C220 110, 126 110, 126 76"/><rect x="142" y="52" width="58" height="24" rx="5"/><text x="171" y="68">memory</text><rect x="142" y="82" width="58" height="24" rx="5"/><text x="171" y="98">plan</text><rect class="fresh" x="246" y="64" width="44" height="24" rx="5"/><text x="268" y="80">fresh</text></svg><p>Reset from durable context.</p>`,
  `<svg class="scene-svg scene-scope" viewBox="0 0 320 150" role="img" aria-label="Failure diagnostic scope"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><rect class="scope" x="34" y="42" width="126" height="66" rx="7"/><path class="wave" d="M48 76 H70 L78 54 L92 100 L104 76 H122 L130 58 L144 94 H152"/><g class="findings"><rect x="196" y="42" width="62" height="24" rx="5"/><text x="227" y="58">scope</text><rect x="196" y="72" width="62" height="24" rx="5"/><text x="227" y="88">context</text><rect class="fix" x="196" y="102" width="62" height="24" rx="5"/><text x="227" y="118">fix</text></g></svg><p>Failure becomes diagnostic signal.</p>`,
  `<svg class="scene-svg scene-standard" viewBox="0 0 320 150" role="img" aria-label="Transferable team standard"><rect class="stage" x="10" y="18" width="300" height="114" rx="7"/><g class="people"><circle cx="54" cy="60" r="16"/><text x="54" y="64">A</text><circle cx="92" cy="60" r="16"/><text x="92" y="64">B</text><circle cx="130" cy="60" r="16"/><text x="130" y="64">C</text></g><path class="merge" d="M54 78 C70 108, 170 108, 188 78 M92 78 C104 100, 172 100, 188 78 M130 78 C142 92, 174 92, 188 78"/><g class="standard"><rect x="190" y="42" width="86" height="68" rx="7"/><text x="233" y="64">method</text><rect x="204" y="78" width="58" height="22" rx="5"/><text x="233" y="93">quality</text></g></svg><p>The method travels across the team.</p>`,
];
---
<div class={`p-demo demo-${number}`} aria-label={`Visual demonstration for commitment ${number}`} set:html={demos[index] ?? demos[0]} />
